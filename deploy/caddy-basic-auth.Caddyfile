:80 {
	root * /srv/html-lore/public
	encode zstd gzip

	basic_auth {
		{$HTML_LORE_BASIC_AUTH_USER} {$HTML_LORE_BASIC_AUTH_HASH}
	}

	request_body {
		max_size 10MB
	}

	handle /api/* {
		reverse_proxy api:8787 {
			header_up Authorization "Bearer {$HTML_LORE_API_TOKEN}"
		}
	}

	handle {
		try_files {path} /index.html
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer-when-downgrade
	}
}
